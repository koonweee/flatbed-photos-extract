# Leave APP_PASSWORD blank for passwordless local/private use.
# Set it for any shared or production deployment.
APP_PASSWORD=

# Optional. If blank, the app uses APP_PASSWORD as the session secret when set.
SESSION_SECRET=

DEV_PORT=8001
DEV_DATA_DIR=./data-dev
MAX_PARALLEL_SCANS=2
WRITE_DEBUG=true
DEBUG_PANEL_WIDTH=
MIN_FREE_DISK_GB=10
